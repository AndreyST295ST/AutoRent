# ===== Application =====
APP_NAME=AutoRent
DEBUG=False
SECRET_KEY=CHANGE_ME_TO_64_RANDOM_CHARACTERS

# ===== Database =====
POSTGRES_DB=autorent
POSTGRES_USER=autorent_user
POSTGRES_PASSWORD=autorent_password
DATABASE_URL=postgresql+asyncpg://autorent_user:autorent_password@db:5432/autorent

# ===== JWT =====
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Auth / Demo =====
REQUIRE_EMAIL_ACTIVATION=False
ENABLE_DEMO_ADMIN=True
DEMO_ADMIN_LOGIN=admin
DEMO_ADMIN_EMAIL=admin@autorent.ru
DEMO_ADMIN_PASSWORD=admin

# ===== Auth Cookies =====
AUTH_COOKIE_NAME=access_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

# ===== Upload security =====
MAX_DOCUMENT_FILE_SIZE_MB=10
MAX_CAR_PHOTO_FILE_SIZE_MB=10
MAX_CAR_PHOTOS_PER_UPLOAD=8
SQL_ECHO=False

# ===== Email =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=andreystep295@gmail.com
SMTP_PASSWORD=bevo vzrx tbyf ulzi

SMTP_STARTTLS=True
SMTP_USE_TLS=False
EMAIL_FROM=andreystep295@gmail.com

# ===== Frontend =====
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8001

# ===== pgAdmin =====
PGADMIN_DEFAULT_EMAIL=admin@autorent.ru
PGADMIN_DEFAULT_PASSWORD=admin
